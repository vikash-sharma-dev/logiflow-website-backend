<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style>
      body {
        margin: 0;
        padding: 40px 15px;
        background: #0f172a;
        font-family: Arial, Helvetica, sans-serif;
      }

      .wrapper {
        max-width: 620px;
        margin: auto;
      }

      .card {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
      }

      /* Header */

      .header {
        background: linear-gradient(135deg, #06b6d4, #14b8a6);
        padding: 45px 30px;
        text-align: center;
      }

      .header h1 {
        margin: 0;
        color: #ffffff;
        font-size: 34px;
        font-weight: 800;
        letter-spacing: -1px;
      }

      .header p {
        margin-top: 12px;
        color: rgba(255, 255, 255, 0.92);
        font-size: 15px;
        line-height: 1.7;
      }

      /* Main */

      .content {
        padding: 35px 28px;
        background: #9dcfef61;
      }

      .title {
        text-align: center;
        margin-bottom: 28px;
      }

      .title h2 {
        margin: 0;
        color: #0f172a;
        font-size: 26px;
        font-weight: 800;
      }

      .title p {
        margin-top: 8px;
        color: #64748b;
        font-size: 14px;
      }

      /* User Info Layout */

      .info-layout {
        background: linear-gradient(135deg, #0f172a, #111827);

        border-radius: 22px;
        padding: 24px;
      }

      .info-card {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 18px;
      }

      .info-card:last-child {
        margin-bottom: 0;
      }

      .label {
        color: #67e8f9;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
      }

      .value {
        color: #ffffff !important;
        font-size: 20px;
        font-weight: 700;
        line-height: 1.5;
        word-break: break-word;
        text-decoration: none !important;
      }

      .value a {
        color: #ffffff !important;
        text-decoration: none !important;
      }

      /* Footer */

      .footer {
        background: #ffffff;
        padding: 22px;
        text-align: center;
        border-top: 1px solid #e2e8f0;
      }

      .footer p {
        margin: 0;
        color: #64748b;
        font-size: 13px;
        line-height: 1.7;
      }

      .badge {
        display: inline-block;
        margin-top: 14px;
        background: #0f172a;
        color: #ffffff;
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
      }

      @media only screen and (max-width: 600px) {
        .header {
          padding: 35px 20px;
        }

        .header h1 {
          font-size: 28px;
        }

        .content {
          padding: 24px 18px;
        }

        .value {
          font-size: 17px;
        }
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="card">
        <!-- Header -->

        <div class="header">
          <h1>📩 New Inquiry Received</h1>

          <p>A customer has submitted a callback request from your website.</p>
        </div>

        <!-- Content -->

        <div class="content">
          <div class="title">
            <h2>Customer Details</h2>

            <p>Review the submitted customer information below.</p>
          </div>

          <!-- User Info -->

          <div class="info-layout">
            <!-- Name -->

            <div class="info-card">
              <div class="label">Full Name</div>

              <div class="value"><%= name %></div>
            </div>

            <!-- Email -->

            <div class="info-card">
              <div class="label">Email Address</div>

              <div class="value"><%= email %></div>
            </div>

            <!-- Phone -->

            <div class="info-card">
              <div class="label">Phone Number</div>

              <div class="value"><%= phone %></div>
            </div>
        <!-- Company (Optional) --> 
          <% if(company && company.trim() !== "") { %> 
            <div class="info-card">
               <div class="label"> Company </div> 
            <div class="value"> <%= company %> </div> 
          </div> <% } %>

         <!-- Shipment Type (Optional) --> 
          <% if(shipmentType && shipmentType.trim() !== "") { %> 
            <div class="info-card"> 
              <div class="label"> Shipment Type </div>
             <div class="value"> <%= shipmentType %> </div> 
            </div> <% } %> 

             <!-- Message (Optional) -->
               <% if(message && message.trim() !== "") { %> 
                <div class="info-card">
                   <div class="label"> Message </div>
                 <div class="value"> <%= message %> </div> 
                </div> <% } %>
            
        <!-- Footer -->

        <div class="footer">
          <p>
            This inquiry was automatically generated from your website form.
          </p>

          <div class="badge">Website Inquiry Notification</div>
        </div>
      </div>
    </div>
  </body>
</html>

